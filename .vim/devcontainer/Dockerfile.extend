ARG BASE_IMAGE
FROM ${BASE_IMAGE}

RUN apt-get update && \
    apt-get install -y software-properties-common && \
    \
    add-apt-repository --yes ppa:jonathonf/vim && \
    apt-get update && \
    \
    apt-get install -y \
        vim-gtk3 \
        tmux \
        git \
        clangd \
        curl && \
    rm -rf /var/lib/apt/lists/*
